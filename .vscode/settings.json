{
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.vscode": true,
    "**/.gitignore": true,
    "**/.pio": true,
    "**/.clang-format": true
  },
  "search.exclude": {
    "**/README.md": true,
    "**/.pio": true,
    "**/.git": true,
    "**/.vscode": true,
    "**/.clang-format": true
  },
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python.defaultInterpreterPath": "${workspaceFolder}/bridge/.venv/Scripts/python.exe",
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "webui[\\\\/]src[\\\\/]assets[\\\\/]css[\\\\/].*\\.css$",
        "cmd": "bun run --cwd ./webui dev-bundle-css"
      },
      {
        "match": "webui[\\\\/]src[\\\\/]assets[\\\\/]js[\\\\/].*\\.js$",
        "cmd": "bun run --cwd ./webui dev-bundle-js"
      }
    ]
  }
}
