{
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.vscode": true,
    "**/.gitignore": true,
    "**/.pio": true,
    "**/.clang-format": true
  },
  "search.exclude": {
    "**/README.md": true,
    "**/.pio": true,
    "**/.git": true,
    "**/.vscode": true,
    "**/.clang-format": true
  },
  "python.terminal.activateEnvironment": false,
  "python.defaultInterpreterPath": "${workspaceFolder}/bridge/.venv/Scripts/python.exe",
  "html.format.unformattedContentDelimiter": "<!--noformat-->",
  "html.format.contentUnformatted": "svg",
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "webui[\\\\/]src[\\\\/]assets[\\\\/]css[\\\\/].*\\.css$",
        "cmd": "bun run --cwd ./webui bundle-css"
      },
      {
        "match": "webui[\\\\/]src[\\\\/]assets[\\\\/]js[\\\\/].*\\.js$",
        "cmd": "bun run --cwd ./webui bundle-js"
      },
      {
        "match": "webui[\\\\/]src[\\\\/]build.json$",
        "cmd": "bun run --cwd ./webui bundle-js"
      },
      {
        "match": "webui[\\\\/]src[\\\\/]index.html$",
        "cmd": "bun run --cwd ./webui bundle-html"
      }
    ]
  }
}
