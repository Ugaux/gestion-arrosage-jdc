{
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.vscode": true,
    "**/.gitignore": true,
    "**/.pio": true,
    "**/.clang-format": true
  },
  "search.exclude": {
    "**/README.md": true,
    "**/.pio": true,
    "**/.git": true,
    "**/.vscode": true,
    "**/.clang-format": true
  },
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python.defaultInterpreterPath": "${workspaceFolder}/bridge/.venv/Scripts/python.exe",
  "platformio-ide.autoRebuildAutocompleteIndex": false // TODO: maybe remove it ?
  //"platformio-ide.autoPreloadEnvTasks": false
}
