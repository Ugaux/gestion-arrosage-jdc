{
  "version": "2.0.0",
  "tasks": [
    // ****************** BRIDGE ****************** //
    {
      "label": "bridge: live refresh",
      "type": "shell",
      "command": "cd bridge && uv run ./live_refresh.py"
    },
    {
      "label": "bridge: dev (mock)",
      "type": "shell",
      "command": "cd bridge && uv run ./start_bridge.py --dev_mode --mock_esp_api"
    },
    {
      "label": "bridge: dev (esp32)",
      "type": "shell",
      "command": "cd bridge && uv run ./start_bridge.py --dev_mode"
    },
    {
      "label": "🌍 bridge: live refresh + dev (mock)",
      "dependsOrder": "parallel",
      "dependsOn": ["bridge: dev live refresh", "bridge: dev (mock)"],
      "problemMatcher": []
    },
    {
      "label": "🌍 bridge: live refresh + dev (esp32)",
      "dependsOrder": "parallel",
      "dependsOn": ["bridge: dev live refresh", "bridge: dev (esp32)"],
      "problemMatcher": []
    },
    {
      "label": "🌍 bridge: prod",
      "type": "shell",
      "command": "cd bridge && uv run ./start_bridge.py"
    },

    // ****************** ESP32: FILESYSTEM SIDE ****************** //
    {
      "label": "🔨 esp32-fs: deploy webui app",
      "type": "shell",
      "command": "bun run --cwd ./webui deploy-app"
    },
    {
      "label": "⬆️ esp32-fs: upload fs image (USB)",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe",
      "args": ["run", "-e", "ESP32-release", "--target", "uploadfs"],
      "options": {
        "cwd": "${workspaceFolder}/firmware"
      }
    },
    {
      "label": "⬆️ esp32-fs: upload fs image (OTA)",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\pio.exe",
      "args": ["run", "-e", "ESP32-release-ota", "--target", "uploadfs"],
      "options": {
        "cwd": "${workspaceFolder}/firmware"
      }
    },
    {
      "label": "🚀 esp32-fs: deploy fs (USB)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "esp32-fs: deploy webui app",
        "esp32-fs: upload fs image (USB)"
      ],
      "problemMatcher": []
    },
    {
      "label": "🚀 esp32-fs: deploy fs (OTA)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "esp32-fs: deploy webui app",
        "esp32-fs: upload fs image (OTA)"
      ],
      "problemMatcher": []
    }
  ]
}
