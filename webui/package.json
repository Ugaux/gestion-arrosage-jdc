{
  "scripts": {
    "convert-fonts": "bun run ./build/convert_fonts.js",
    "clean-app": "bun run ./build/clean_app.js",
    "bundle-js": "bun run ./build/bundle_js.js",
    "bundle-css": "bun run ./build/bundle_css.js",
    "bundle-html": "bun run ./build/bundle_html.js",
    "copy-assets": "bun run ./build/copy_assets.js",
    "build-app": "bun run clean-app && bun run bundle-js && bun run bundle-css && bun run bundle-html && bun run copy-assets",
    "deploy-app": "bun run build-app && bun run ./build/deploy.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lightningcss": "^1.32.0"
  },
  "dependencies": {
    "dedent": "^1.7.2",
    "html-minifier-terser": "^7.2.0"
  }
}
